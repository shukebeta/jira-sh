def _inline(children):
    out = []
    for tok in children or []:
        t = tok.get("type")
        if t == "text":
            if tok.get("raw"):
                out.append({"type": "text", "text": tok["raw"]})
        elif t == "codespan":
            if tok.get("raw"):
                out.append({"type": "text", "text": tok["raw"], "marks": [{"type": "code"}]})
        elif t == "link":
            href = (tok.get("attrs") or {}).get("url", "")
            kids = _inline(tok.get("children", [])) or ([{"type": "text", "text": href}] if href else [])
            for n in kids:
                if n.get("type") == "text":
                    n.setdefault("marks", []).append({"type": "link", "attrs": {"href": href}})
            out.extend(kids)
        elif t == "strong":
            kids = _inline(tok.get("children", []))
            for n in kids:
                if n.get("type") == "text" and not any(m.get("type") == "code" for m in n.get("marks", [])):
                    n.setdefault("marks", []).append({"type": "strong"})
            out.extend(kids)
        elif t == "emphasis":
            kids = _inline(tok.get("children", []))
            for n in kids:
                if n.get("type") == "text" and not any(m.get("type") == "code" for m in n.get("marks", [])):
                    n.setdefault("marks", []).append({"type": "em"})
            out.extend(kids)
        elif t in ("linebreak", "softbreak"):
            out.append({"type": "hardBreak"})
        elif tok.get("raw"):
            out.append({"type": "text", "text": tok["raw"]})
    return out

def _blocks(tokens):
    out = []
    for tok in tokens or []:
        t = tok.get("type")
        if t == "blank_line":
            continue
        elif t == "heading":
            lvl = min(6, (tok.get("attrs") or {}).get("level", 1))
            c_nodes = _inline(tok.get("children", []))
            if c_nodes:
                out.append({"type": "heading", "attrs": {"level": lvl}, "content": c_nodes})
        elif t in ("paragraph", "block_text"):
            c_nodes = _inline(tok.get("children", []))
            if c_nodes:
                out.append({"type": "paragraph", "content": c_nodes})
        elif t == "block_quote":
            inner = _blocks(tok.get("children", [])) or [{"type": "paragraph"}]
            out.append({"type": "blockquote", "content": inner})
        elif t == "list":
            ordered = (tok.get("attrs") or {}).get("ordered", False)
            items = []
            for li in tok.get("children", []):
                inner = _blocks(li.get("children", [])) or [{"type": "paragraph"}]
                items.append({"type": "listItem", "content": inner})
            if items:
                out.append({"type": "orderedList" if ordered else "bulletList", "content": items})
        elif t == "thematic_break":
            out.append({"type": "rule"})
        elif t == "block_code":
            code = tok.get("raw", "")
            out.append({"type": "codeBlock", "content": [{"type": "text", "text": code}]})
        elif tok.get("raw"):
            out.append({"type": "paragraph", "content": [{"type": "text", "text": tok["raw"]}]})
    return out

def md_to_adf_doc(text):
    if not text:
        return None
    try:
        import mistune
        md = mistune.create_markdown(renderer=None)
        content = _blocks(md(text))
    except ImportError:
        sys.stderr.write("jr: mistune not installed — body sent as plain text. Install with: pip install mistune\n")
        content = [
            {"type": "paragraph", "content": [{"type": "text", "text": para.strip()}]}
            for para in text.split("\n\n") if para.strip()
        ]
    if not content:
        return None
    return {"type": "doc", "version": 1, "content": content}

# ── Build payload ─────────────────────────────────────────────────────────────
fields = {
