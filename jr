      --body)         body=$2;      shift 2 ;;
      --body-file)    body_file=$2; shift 2 ;;
      --dry-run)      dry_run=1;    shift ;;
      --force|-f)     force=1;      shift ;;
      -*)
        echo "jr edit: unknown flag '$1'" >&2
        echo "Usage: jr edit [TICKET] [--title \"...\"] [--body \"...\"|--body-file path] [--force] [--dry-run]" >&2
        return 1 ;;
