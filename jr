#!/usr/bin/env bash
# jr - Jira Cloud CLI

# On Windows, python's text-mode stdout translates \n to \r\n, and bash's
# `read`/`$()` keep the trailing \r — silently poisoning every value we capture
# (breaks string compares, embeds \r in JSON, garbles output via carriage
# returns). Strip it at the single source so callers never see it.
python3() { command python3 "$@" | tr -d '\r'; }

_jr_check_env() {
  local missing=()
  [[ -z "${JIRA_BASE:-}"  ]] && missing+=(JIRA_BASE)
  [[ -z "${JIRA_EMAIL:-}" ]] && missing+=(JIRA_EMAIL)
  [[ -z "${JIRA_TOKEN:-}" ]] && missing+=(JIRA_TOKEN)
  JIRA_PROJECT_PREFIXES=${JIRA_PROJECT_PREFIXES:-MT|DOS}
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "jr: missing env vars: ${missing[*]}" >&2
    echo "    Set them in ~/.bashrc or source a .env file" >&2
    exit 1
  fi
}

_jr_resolve_ticket() {
  local t=$1
  # Branch-derived ticket: empty / '.' / '@' means "the current branch's ticket".
  # Extract (<PREFIX>)-<n> from the checked-out branch using JIRA_PROJECT_PREFIXES.
  if [[ -z "$t" || "$t" == "." || "$t" == "@" ]]; then
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || {
      echo "jr: not in a git repo; cannot derive ticket from the branch" >&2; return 1; }
    local key
    key=$(echo "$branch" | grep -oiE "(${JIRA_PROJECT_PREFIXES})-[0-9]+" | head -1)
    if [[ -z "$key" ]]; then
      echo "jr: no ticket key (${JIRA_PROJECT_PREFIXES}) found in branch '$branch'" >&2
      return 1
    fi
    echo "$key" | tr '[:lower:]' '[:upper:]'
    return 0
  fi
  if [[ ! "$t" =~ ^[0-9]+$ ]]; then
    echo "$t"; return 0
  fi
  local prefixes
  IFS='|' read -ra prefixes <<< "${JIRA_PROJECT_PREFIXES:-}"
  if [[ ${#prefixes[@]} -eq 1 ]]; then
    echo "${prefixes[0]}-${t}"; return 0
  fi
  local p
  for p in "${prefixes[@]}"; do
    if _jr_api GET "/issue/${p}-${t}?fields=summary" &>/dev/null; then
      echo "${p}-${t}"; return 0
    fi
  done
  echo "jr: cannot resolve #${t} under prefixes: ${prefixes[*]}" >&2
  return 1
}

_jr_auth() {
  echo -n "$JIRA_EMAIL:$JIRA_TOKEN" | base64 | tr -d '\n'
}

# Print the current Jira user's accountId and displayName on two lines.
_jr_myself() {
  _jr_api GET "/myself" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(d.get('accountId', ''))
print(d.get('displayName', ''))
"
}

_jr_api() {
  local method=$1 path=$2 data=${3:-}
  local url="$JIRA_BASE/rest/api/3$path"
  local auth
  auth=$(_jr_auth)
  local args=(-s -f -X "$method"
    -H "Authorization: Basic $auth"
    -H "Content-Type: application/json"
    -H "Accept: application/json")
  [[ -n "$data" ]] && args+=(-d "$data")
  curl "${args[@]}" "$url"
}

# Like _jr_api but without -f: emits the response body followed by a final
# line containing the HTTP status code, so callers can inspect both.
_jr_api_status() {
  local method=$1 path=$2 data=${3:-}
  local url="$JIRA_BASE/rest/api/3$path"
  local auth
  auth=$(_jr_auth)
  local args=(-s -w '\n%{http_code}' -X "$method"
    -H "Authorization: Basic $auth"
    -H "Content-Type: application/json"
    -H "Accept: application/json")
  [[ -n "$data" ]] && args+=(-d "$data")
  curl "${args[@]}" "$url"
}

# POST a transition, reporting real failures. Some transitions enforce a
# "Time Spent" validator; we then prompt for the time to log (Jira's documented
# bypass is 0m, which is the default if you just press Enter).
# Transitions to "Ready" may also require a CapEx field; configure it in
# ~/.jr.toml under [move.capex] with field, yes_value, and no_value keys.
_jr_do_transition() {
  local ticket=$1 tid=$2 status=$3
  local resp code body
  resp=$(_jr_api_status POST "/issue/$ticket/transitions" "{\"transition\":{\"id\":\"$tid\"}}")
  code=${resp##*$'\n'}; body=${resp%$'\n'*}
  if [[ ! "$code" =~ ^2 ]] && echo "$body" | grep -qi "time spent"; then
    local spent
    read -r -p "$status requires a Time Spent (e.g. 30m, 1h). [Enter = 0m to bypass]: " spent
    spent=${spent:-0m}
    resp=$(_jr_api_status POST "/issue/$ticket/transitions" \
      "{\"transition\":{\"id\":\"$tid\"},\"update\":{\"worklog\":[{\"add\":{\"timeSpent\":\"$spent\"}}]}}")
    code=${resp##*$'\n'}; body=${resp%$'\n'*}
  fi
  if [[ ! "$code" =~ ^2 ]] && echo "$body" | grep -qi "capex"; then
    local capex_field capex_yes capex_no
    { read -r capex_field; read -r capex_yes; read -r capex_no; } < <(python3 -c "
import os, sys
try:
    try:
        import tomllib
    except ImportError:
        import tomli as tomllib
    with open(os.path.expanduser('~/.jr.toml'), 'rb') as f:
        cfg = tomllib.load(f)
    cap = cfg.get('move', {}).get('capex', {})
    print(cap.get('field', ''))
    print(cap.get('yes_value', 'Yes'))
    print(cap.get('no_value', 'No'))
except Exception:
    print('')
    print('Yes')
    print('No')
")
    if [[ -z "$capex_field" ]]; then
      echo "jr: '$status' requires a CapEx field. Add to ~/.jr.toml:" >&2
      echo "    [move.capex]" >&2
      echo "    field     = \"customfield_XXXXX\"  # CapEx custom field ID" >&2
      echo "    yes_value = \"Yes\"                # optional, default Yes" >&2
      echo "    no_value  = \"No\"                 # optional, default No" >&2
      return 1
    fi
    local capex_answer capex_value
    read -r -p "CapEx? [y/N]: " capex_answer
    capex_value=$( [[ "${capex_answer,,}" == "y" ]] && echo "$capex_yes" || echo "$capex_no" )
    # CapEx lives on the transition screen, not the edit screen — include it in
    # the transition body's fields rather than PATCHing the issue separately.
    resp=$(_jr_api_status POST "/issue/$ticket/transitions" \
      "{\"transition\":{\"id\":\"$tid\"},\"fields\":{\"$capex_field\":{\"value\":\"$capex_value\"}}}")
    code=${resp##*$'\n'}; body=${resp%$'\n'*}
  fi
  if [[ ! "$code" =~ ^2 ]]; then
    echo "jr: failed to move $ticket to '$status' (HTTP $code)" >&2
    echo "$body" | python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    for m in d.get('errorMessages', []): print('   ', m)
    for k, v in d.get('errors', {}).items(): print(f'    {k}: {v}')
except Exception:
    pass
" >&2
    return 1
  fi
}

_jr_json_comment_body() {
  python3 -c "
import json, sys
print(json.dumps({
  'body': {
    'type': 'doc', 'version': 1,
    'content': [{'type': 'paragraph', 'content': [{'type': 'text', 'text': sys.argv[1]}]}]
  }
}))" "$1"
}

cmd_move() {
  [[ $# -lt 2 ]] && { echo "Usage: jr move <TICKET> <STATUS>" >&2; return 1; }
  local ticket status
  ticket=$(_jr_resolve_ticket "$1") || return 1; status=$2

  # Resolve the transition (and its destination name) first.
  local transitions
  transitions=$(_jr_api GET "/issue/$ticket/transitions") || { echo "jr: ticket not found: $ticket" >&2; return 1; }
  local result
  result=$(echo "$transitions" | python3 -c "
import json, sys
target = sys.argv[1].lower()
ts = json.loads(sys.stdin.read()).get('transitions', [])
def emit(t): print('OK:%s:%s' % (t['id'], t.get('to', {}).get('name', '')))
for t in ts:
    dest = t.get('to', {}).get('name', '').lower()
    if dest == target or t['name'].lower() == target:
        emit(t); sys.exit(0)
words = target.split()
matches = [t for t in ts if all(w in t.get('to', {}).get('name', '').lower() for w in words)]
if len(matches) == 1:
    emit(matches[0]); sys.exit(0)
if len(matches) > 1:
    print('AMBIGUOUS:' + ', '.join(t.get('to', {}).get('name', '') for t in matches))
else:
    print('NONE:')
" "$status")

  local tid dest
  case "$result" in
    OK:*)        dest=${result#OK:*:}; tid=${result#OK:}; tid=${tid%%:*} ;;
    AMBIGUOUS:*) echo "jr: '$status' is ambiguous: ${result#AMBIGUOUS:}" >&2; return 1 ;;
    *)           echo "jr: no transition to '$status'. Available targets:" >&2
                 echo "$transitions" | python3 -c "
import json, sys
for t in json.loads(sys.stdin.read()).get('transitions', []):
    print(' ', t['name'])
" >&2; return 1 ;;
  esac

  # Current assignee — accountId is reliable even when Jira hides the email.
  local a_id a_email
  { read -r a_id; read -r a_email; } < <(_jr_api GET "/issue/$ticket?fields=assignee" | python3 -c "
import json, sys
a = json.loads(sys.stdin.read()).get('fields', {}).get('assignee') or {}
print(a.get('accountId', ''))
print(a.get('emailAddress', ''))
")

  # Identify the current user by accountId — reliable even when Jira hides the
  # assignee's email, so we never depend on $JIRA_EMAIL matching what Jira reports.
  local me_id me_name
  { read -r me_id; read -r me_name; } < <(_jr_myself)
  [[ -n "$me_id" ]] || { echo "jr: could not determine the current Jira user" >&2; return 1; }

  if [[ "${dest,,}" == *"in progress"* ]]; then
    # Starting work claims the ticket: take it if unassigned, refuse if it's
    # someone else's, no-op if it's already yours.
    if [[ -z "$a_id" ]]; then
      _jr_api PUT "/issue/$ticket/assignee" "{\"accountId\":\"$me_id\"}" > /dev/null \
        || { echo "jr: failed to assign $ticket to you" >&2; return 1; }
      echo "$ticket → assigned to you (${me_name:-current user})"
    elif [[ "$a_id" != "$me_id" ]]; then
      echo "jr: $ticket is assigned to ${a_email:-someone else}, not you — not moving to '$dest'." >&2
      echo "    Re-assign it to yourself first if you're taking over." >&2
      return 1
    fi
  elif [[ -n "$a_id" && "$a_id" != "$me_id" ]]; then
    echo "jr: $ticket is assigned to ${a_email:-someone else}, not you."
    read -r -p "Move anyway? [y/N] " confirm
    [[ "${confirm,,}" == "y" ]] || { echo "aborted." >&2; return 1; }
  fi

  _jr_do_transition "$ticket" "$tid" "$dest" || return 1
  echo "$ticket → $dest"
}

# Start work on a ticket: reach "In Progress" from wherever it is now. Jira's
# workflow blocks a direct Refinement/Analysis → In Progress jump, so when the
# direct transition is missing we hop through "Ready" first. Delegates each hop
# to cmd_move, which claims the ticket and handles the CapEx/Time-Spent gates.
cmd_start() {
  local ticket
  ticket=$(_jr_resolve_ticket "${1:-.}") || return 1

  local transitions
  transitions=$(_jr_api GET "/issue/$ticket/transitions") \
    || { echo "jr: ticket not found: $ticket" >&2; return 1; }

  # Classify the reachable destinations in one pass: is "In Progress" directly
  # available, and failing that, is "Ready" available as a stepping stone?
  local reach
  reach=$(echo "$transitions" | python3 -c "
import json, sys
dests = [t.get('to', {}).get('name', '').lower() for t in json.loads(sys.stdin.read()).get('transitions', [])]
if any('in progress' in d for d in dests): print('DIRECT')
elif any(d == 'ready' for d in dests):     print('VIA_READY')
else:                                       print('NONE')
")

  case "$reach" in
    DIRECT)
      cmd_move "$ticket" "In Progress" ;;
    VIA_READY)
      echo "$ticket: In Progress not directly reachable — hopping through Ready."
      cmd_move "$ticket" "Ready" || return 1
      cmd_move "$ticket" "In Progress" ;;
    *)
      echo "jr: cannot reach 'In Progress' from $ticket's current status. Available targets:" >&2
      echo "$transitions" | python3 -c "
import json, sys
for t in json.loads(sys.stdin.read()).get('transitions', []):
    print(' ', t.get('to', {}).get('name', t['name']))
" >&2
      return 1 ;;
  esac
}

cmd_comment() {
  [[ $# -lt 2 ]] && { echo "Usage: jr comment <TICKET> <TEXT>" >&2; return 1; }
  local ticket
  ticket=$(_jr_resolve_ticket "$1") || return 1; shift
  local body
  body=$(_jr_json_comment_body "$*") || return 1
  _jr_api POST "/issue/$ticket/comment" "$body" > /dev/null
  echo "comment added to $ticket"
}

cmd_comments() {
  local n=3 ticket_arg="."
  local a
  for a in "$@"; do
    if [[ "$a" =~ ^-[0-9]+$ ]]; then n=${a#-}
    else ticket_arg=$a
    fi
  done
  local ticket
  ticket=$(_jr_resolve_ticket "$ticket_arg") || return 1

  _jr_api GET "/issue/$ticket/comment?orderBy=-created&maxResults=$n" | python3 -c "$(cat <<'PYEOF'
import json, sys

data = json.load(sys.stdin)
comments = list(reversed(data.get('comments', [])))
total = data.get('total', 0)
shown = len(comments)

def wrap(text, marks):
    for m in marks or []:
        t = m.get('type')
        if   t == 'code':   text = '`%s`' % text
        elif t == 'strong': text = '**%s**' % text
        elif t == 'em':     text = '*%s*' % text
        elif t == 'strike': text = '~~%s~~' % text
        elif t == 'link':   text = '[%s](%s)' % (text, (m.get('attrs') or {}).get('href', ''))
    return text

def inline(nodes):
    out = ''
    for n in nodes or []:
        t = n.get('type')
        a = n.get('attrs') or {}
        if   t == 'text':       out += wrap(n.get('text', ''), n.get('marks'))
        elif t == 'hardBreak':  out += '\n'
        elif t == 'emoji':      out += a.get('text') or a.get('shortName', '')
        elif t == 'mention':    out += '@' + (a.get('text') or '').lstrip('@')
        elif t == 'inlineCard': out += a.get('url', '')
        elif t == 'status':     out += '[%s]' % a.get('text', '')
        elif 'content' in n:    out += inline(n['content'])
    return out

def block(nodes, indent=0):
    lines = []
    pad = '  ' * indent
    for n in nodes or []:
        t = n.get('type')
        a = n.get('attrs') or {}
        if t == 'paragraph':
            lines.append(pad + inline(n.get('content')))
        elif t == 'heading':
            lines.append(pad + '#' * a.get('level', 1) + ' ' + inline(n.get('content')))
        elif t in ('bulletList', 'orderedList'):
            ordered = t == 'orderedList'
            for i, li in enumerate(n.get('content', []), 1):
                inner = block(li.get('content', []), indent + 1)
                marker = ('%d.' % i) if ordered else '-'
                pos = next((k for k, l in enumerate(inner) if l.strip()), None)
                if pos is None: inner = [pad + marker + ' ']
                else: inner[pos] = pad + marker + ' ' + inner[pos].lstrip()
                lines += inner
        elif t == 'taskList':
            for ti in n.get('content', []):
                box = '[x]' if (ti.get('attrs') or {}).get('state') == 'DONE' else '[ ]'
                lines.append(pad + '- ' + box + ' ' + inline(ti.get('content')))
        elif t == 'codeBlock':
            lines.append(pad + '```' + (a.get('language') or ''))
            lines.append(inline(n.get('content')))
            lines.append(pad + '```')
        elif t == 'blockquote':
            for l in block(n.get('content', []), indent):
                lines.append((pad + '> ' + l) if l else (pad + '>'))
        elif t == 'rule':
            lines.append(pad + '---')
        elif t == 'panel':
            lines.append(pad + '[%s]' % (a.get('panelType') or 'note'))
            lines += block(n.get('content', []), indent)
        elif t == 'table':
            for row in n.get('content', []):
                cells = []
                for cell in row.get('content', []):
                    cells.append(' '.join(block(cell.get('content', []))).replace('\n', ' ').strip())
                lines.append(pad + '| ' + ' | '.join(cells) + ' |')
        elif 'content' in n:
            lines += block(n['content'], indent)
    return lines

if shown < total:
    print('Showing last %d of %d comments' % (shown, total))
for c in comments:
    author = (c.get('author') or {}).get('displayName', 'Unknown')
    ts = c.get('created', '')[:16].replace('T', ' ')
    print()
    print('%s  %s' % (author, ts))
    body = c.get('body', {})
    if isinstance(body, dict) and body.get('content'):
        text = '\n'.join(block(body['content'])).strip('\n')
        print(text if text.strip() else '  (empty)')
    elif isinstance(body, str) and body.strip():
        print(body)
    else:
        print('  (empty)')
    print('---')
PYEOF
)"
}

# Build the "Resolved" comment ADF from gh PR JSON ({body,url}) read from the
# PR_JSON env var. Emits {"body": <doc>} on stdout. Exits 2 if mistune is
# missing (with an install hint) so the caller can surface it.
_jr_resolve_adf() {
  PR_JSON="$1" DDT_FILES="$2" python3 <<'PYEOF'
import json, os, re, sys

try:
    import mistune
except ImportError:
    sys.stderr.write("jr: mistune is required to render the PR body into ADF.\n")
    sys.stderr.write("    Install it with: pip install mistune\n")
    sys.exit(2)

try:
    pr = json.loads(os.environ.get("PR_JSON", "") or "{}")
except Exception as e:
    sys.stderr.write("jr: could not parse PR JSON from gh: %s\n" % e)
    sys.exit(1)

body_md = (pr.get("body") or "").strip()
url = pr.get("url") or ""

# A newly-added file under DFXSQL/DDT/UpdateScripts/ means a DDT script was
# introduced in the correct folder — auto-answer the DDT checklist item "Yes".
# DDT_FILES is one "status<TAB>filename" line per PR file (from the REST files
# endpoint, since gh pr view --json files carries no file status).
ddt_yes = False
for _line in (os.environ.get("DDT_FILES") or "").splitlines():
    st, _, fn = _line.partition("\t")
    if st == "added" and re.match(r"^DFXSQL/DDT/UpdateScripts/", fn):
        ddt_yes = True
        break

# Drop the trailing "Generated with [Claude Code]" footer (and a dangling rule).
kept = [ln for ln in body_md.split("\n") if "Generated with [Claude Code]" not in ln]
body_md = re.sub(r"\n-{3,}\s*$", "", "\n".join(kept)).strip()

FLAG = {"type": "emoji", "attrs": {"shortName": ":flag_on:", "id": "atlassian-flag_on", "text": ":flag_on:"}}
Q = {"type": "emoji", "attrs": {"shortName": ":question:", "id": "atlassian-question_mark", "text": ":question:"}}

def add_mark(nodes, mark):
    for n in nodes:
        if n.get("type") == "text":
            # ADF rejects code+strong or code+em on the same node; drop the outer mark.
            if mark.get("type") in ("strong", "em") and any(m.get("type") == "code" for m in n.get("marks", [])):
                continue
            n.setdefault("marks", []).append(mark)
    return nodes

def inline(children):
    out = []
    for tok in children or []:
        t = tok.get("type")
        if t == "text":
            if tok.get("raw"):
                out.append({"type": "text", "text": tok["raw"]})
        elif t == "codespan":
            if tok.get("raw"):
                out.append({"type": "text", "text": tok["raw"], "marks": [{"type": "code"}]})
        elif t == "link":
            href = (tok.get("attrs") or {}).get("url", "")
            kids = inline(tok.get("children", [])) or ([{"type": "text", "text": href}] if href else [])
            out.extend(add_mark(kids, {"type": "link", "attrs": {"href": href}}))
        elif t == "strong":
            out.extend(add_mark(inline(tok.get("children", [])), {"type": "strong"}))
        elif t == "emphasis":
            out.extend(add_mark(inline(tok.get("children", [])), {"type": "em"}))
        elif t == "linebreak":
            out.append({"type": "hardBreak"})
        elif t == "softbreak":
            out.append({"type": "text", "text": " "})
        elif tok.get("raw"):
            out.append({"type": "text", "text": tok["raw"]})
    return out

def para(children):
    p = {"type": "paragraph"}
    c = inline(children)
    if c:
        p["content"] = c
    return p

def blocks(tokens):
    out = []
    for tok in tokens or []:
        t = tok.get("type")
        if t == "blank_line":
            continue
        elif t == "heading":
            # Demote below our level-2 section labels.
            lvl = min(6, (tok.get("attrs") or {}).get("level", 1) + 2)
            c = inline(tok.get("children", []))
            if c:
                out.append({"type": "heading", "attrs": {"level": lvl}, "content": c})
        elif t in ("paragraph", "block_text"):
            out.append(para(tok.get("children", [])))
        elif t == "block_quote":
            inner = blocks(tok.get("children", [])) or [{"type": "paragraph"}]
            out.append({"type": "blockquote", "content": inner})
        elif t == "list":
            ordered = (tok.get("attrs") or {}).get("ordered", False)
            items = []
            for li in tok.get("children", []):
                inner = blocks(li.get("children", [])) or [{"type": "paragraph"}]
                items.append({"type": "listItem", "content": inner})
            if items:
                out.append({"type": "orderedList" if ordered else "bulletList", "content": items})
        elif t == "thematic_break":
            out.append({"type": "rule"})
        elif tok.get("raw"):
            # Unknown token (tables, fenced code, images): degrade to raw text.
            out.append({"type": "paragraph", "content": [{"type": "text", "text": tok["raw"]}]})
    return out

# Lists under these headings are test plans / process checklists, not changes.
SKIP_HEADING = re.compile(r"test|checklist|how\s+to|qa|verif|deploy", re.I)
# A "- [ ] ..." / "- [x] ..." item is a checkbox, never a change description.
CHECKBOX = re.compile(r"^\s*\[[ xX]?\]")

def _text_of(nodes):
    parts = []
    for n in nodes or []:
        if n.get("type") == "text":
            parts.append(n.get("text", ""))
        else:
            parts.append(_text_of(n.get("content")))
    return "".join(parts)

def list_items(tokens):
    """Collect change-list items into a flat sequence of ADF listItems.

    Headings and prose are dropped, and so are *test plans / checklists* — both
    the lists that sit under a Test/Checklist/Deploy heading and individual
    "- [ ]" checkbox items wherever they appear. The Team Leader wants a short
    list of what changed, not the PR's own process checklist (the Resolved
    template already carries its own Checklist section)."""
    items = []
    heading = ""
    for tok in tokens or []:
        t = tok.get("type")
        if t == "heading":
            heading = "".join(c.get("raw", "") for c in tok.get("children", []))
        elif t == "list":
            if SKIP_HEADING.search(heading):
                continue
            for li in tok.get("children", []):
                inner = blocks(li.get("children", [])) or [{"type": "paragraph"}]
                if CHECKBOX.match(_text_of(inner[0].get("content"))):
                    continue
                items.append({"type": "listItem", "content": inner})
    return items

md = mistune.create_markdown(renderer=None)
items = list_items(md(body_md)) if body_md else []

# Fallback: no bullets in the PR body — list the commit subjects instead.
if not items:
    for c in pr.get("commits") or []:
        h = (c.get("messageHeadline") or "").strip()
        if h:
            items.append({"type": "listItem", "content": [
                {"type": "paragraph", "content": [{"type": "text", "text": h}]}]})

if items:
    summary = [{"type": "bulletList", "content": items}]
else:
    summary = [{"type": "paragraph", "content": [{"type": "text", "text": "(no summary)"}]}]

def label(text):
    return {"type": "paragraph", "content": [{"type": "text", "text": text, "marks": [{"type": "strong"}]}]}

def bullet(nodes):
    return {"type": "bulletList", "content": [{"type": "listItem", "content": [{"type": "paragraph", "content": nodes}]}]}

CHECKLIST = [
    "DDT script run using DFXDDT (DeployDFXDDT) & in correct folder - ",
    "Infrastructure Release Notes written - ",
    "API: Source code comments for interface changes - ",
    "Privacy concerns resolved - ",
]
# Item 0 (the DDT item) is answered "Yes" when the PR added a DDT script in the
# correct folder; every other item stays a question mark for the reviewer.
def _suffix(i):
    return {"type": "text", "text": "Yes"} if (i == 0 and ddt_yes) else Q
checklist = [{"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": it}, _suffix(i)]}]} for i, it in enumerate(CHECKLIST)]

pr_link = [{"type": "text", "text": url, "marks": [{"type": "link", "attrs": {"href": url}}]}] if url else [{"type": "text", "text": "(no PR link)"}]

content = [{"type": "heading", "attrs": {"level": 2},
            "content": [FLAG, {"type": "text", "text": " Resolved", "marks": [{"type": "textColor", "attrs": {"color": "#3cb371"}}]}]},
           label("Summary of code changes")]
content += summary
content += [label("Details of dev testing"), bullet([{"type": "text", "text": "Unit tests all pass"}]),
            label("Components changed (and feature branch if applicable)"), bullet(pr_link),
            label("Checklist"), {"type": "bulletList", "content": checklist}]

print(json.dumps({"body": {"type": "doc", "version": 1, "content": content}}))
PYEOF
}

# Build the re-resolve comment ADF for a kicked-back ticket. Moving back to
# review re-triggers the workflow's template, so we edit *that* comment in
# place: keep its title (the first content node) and replace the whole
# checklist body with a one-line "review feedback addressed" note + PR link.
# argv: $1 = the existing comment object (from GET .../comment/<id>), $2 = PR JSON.
_jr_resolve_retry_adf() {
  ORIG_JSON="$1" PR_JSON="$2" python3 <<'PYEOF'
import json, os
FLAG = {"type": "emoji", "attrs": {"shortName": ":flag_on:", "id": "atlassian-flag_on", "text": ":flag_on:"}}
orig = json.loads(os.environ.get("ORIG_JSON", "{}"))
pr = json.loads(os.environ.get("PR_JSON", "{}"))
url = pr.get("url", "")
link = [{"type": "text", "text": url, "marks": [{"type": "link", "attrs": {"href": url}}]}] if url else [{"type": "text", "text": "(no PR link)"}]

# Keep the template's own title (its first content node). Fall back to a flagged
# heading if the existing comment has no content — keeps the atlassian-flag_on
# marker so _jr_resolved_state still recognises this as a filled comment.
orig_content = (orig.get("body") or {}).get("content") or []
title = [orig_content[0]] if orig_content else [
    {"type": "paragraph", "content": [FLAG, {"type": "text", "text": " Review Feedback Resolved", "marks": [{"type": "strong"}]}]}]

sentence = {"type": "paragraph", "content": [
    {"type": "text", "text": "Review feedback addressed — check the latest PR commits: "}, *link]}
content = title + [sentence]
print(json.dumps({"body": {"type": "doc", "version": 1, "content": content}}))
PYEOF
}

# POST/PUT a comment body, reporting non-2xx with the server's error messages.
#   _jr_comment_write POST /issue/K/comment        "$body" "what failed"
#   _jr_comment_write PUT  /issue/K/comment/<id>   "$body" "what failed"
_jr_comment_write() {
  local method=$1 path=$2 body=$3 what=$4
  local resp code errbody
  resp=$(_jr_api_status "$method" "$path" "$body")
  code=${resp##*$'\n'}; errbody=${resp%$'\n'*}
  if [[ ! "$code" =~ ^2 ]]; then
    echo "jr: $what (HTTP $code)" >&2
    echo "$errbody" | python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    for m in d.get('errorMessages', []): print('   ', m)
    for k, v in d.get('errors', {}).items(): print(f'    {k}: {v}')
except Exception:
    pass
" >&2
    return 1
  fi
}

# Classify Resolved comments on a ticket. Reads the comment list on stdin and
# my accountId as argv1; prints one of:
#   TEMPLATE:<id>        unfilled template (any author) — first resolve
#   TEMPLATE_RETRY:<id>  unfilled template AND a prior filled comment (mine) — re-resolve after kickback
#   FILLED:<id>          a Resolved comment filled in by me; no pending template
#   NONE:                no Resolved comment
_jr_resolved_state() {
  python3 -c "
import json, sys
me = sys.argv[1]
template = filled = None
for c in json.load(sys.stdin).get('comments', []):
    body = json.dumps(c.get('body', {}))
    if 'atlassian-flag_on' not in body:
        continue
    is_mine = (c.get('author') or {}).get('accountId') == me
    if any(t in body for t in ('<summary>', '<details>', '<component>')):
        template = c['id']
    elif is_mine:
        filled = c['id']
if template:
    print(('TEMPLATE_RETRY:' if filled else 'TEMPLATE:') + template)
elif filled:
    print('FILLED:' + filled)
else:
    print('NONE:')
" "$1"
}

cmd_resolve() {
  local force=0 rest=()
  local a
  for a in "$@"; do
    case "$a" in
      --force|-f) force=1 ;;
      *)          rest+=("$a") ;;
    esac
  done
  set -- "${rest[@]}"
  local ticket
  ticket=$(_jr_resolve_ticket "${1:-.}") || return 1

  command -v gh >/dev/null 2>&1 || { echo "jr: gh CLI not found (needed to read the PR)" >&2; return 1; }

  # The Resolved comment is built from the *remote* PR (gh pr view). If the local
  # branch has uncommitted or unpushed work, that comment silently omits it —
  # resolve looks successful but lands stale. Warn before proceeding (--force skips).
  if [[ $force -eq 0 ]]; then
    local dirty="" unpushed=""
    [[ -n "$(git status --porcelain 2>/dev/null)" ]] && dirty=1
    git rev-parse '@{u}' >/dev/null 2>&1 \
      && [[ -n "$(git rev-list '@{u}..HEAD' 2>/dev/null)" ]] && unpushed=1
    if [[ -n "$dirty" || -n "$unpushed" ]]; then
      [[ -n "$dirty"    ]] && echo "jr: working tree has uncommitted changes." >&2
      [[ -n "$unpushed" ]] && echo "jr: branch has commits not pushed to the PR's remote." >&2
      echo "    The Resolved comment is built from the pushed PR and won't include them." >&2
      local cont
      read -r -p "Resolve anyway? [y/N] " cont
      [[ "${cont,,}" == "y" ]] || { echo "aborted — push your work first, or use --force." >&2; return 1; }
    fi
  fi

  # PR for the current branch.
  local pr
  if ! pr=$(gh pr view --json body,url,commits 2>&1); then
    echo "jr: no PR found for the current branch." >&2
    echo "    Run from the repo with the feature branch checked out." >&2
    echo "    If this repo needs a specific GitHub account, check gh / GH_PROFILE." >&2
    echo "    gh: $pr" >&2
    return 1
  fi

  # Detect newly-added DFXSQL/DDT/UpdateScripts files so the DDT checklist item
  # can be auto-answered "Yes". gh pr view --json files carries no file status,
  # so hit the REST files endpoint (owner/repo/number parsed from the PR URL).
  local ddt_files="" pr_url api
  pr_url=$(printf '%s' "$pr" | python3 -c "import json,sys;print(json.load(sys.stdin).get('url') or '')")
  api=$(printf '%s' "$pr_url" | python3 -c "
import re, sys
m = re.search(r'/([^/]+/[^/]+)/(?:pull|pulls)/(\d+)', sys.stdin.read())
print(f'repos/{m.group(1)}/pulls/{m.group(2)}/files' if m else '')")
  if [[ -n "$api" ]]; then
    ddt_files=$(gh api "$api" --paginate --jq '.[] | .status + "\t" + .filename' 2>/dev/null) || ddt_files=""
  fi
  [[ -n "$ddt_files" ]] && grep -q $'^added\tDFXSQL/DDT/UpdateScripts/' <<<"$ddt_files" \
    && echo "jr: newly added DFXSQL/DDT/UpdateScripts file detected — marking DDT checklist item Yes."

  # Build the Resolved comment from the PR data (mistune renders the body).
  local body
  body=$(_jr_resolve_adf "$pr" "$ddt_files") || return 1

  local me
  me=$(_jr_api GET "/myself" | python3 -c "import json, sys; print(json.load(sys.stdin).get('accountId', ''))")
  [[ -n "$me" ]] || { echo "jr: could not determine the current Jira user" >&2; return 1; }

  # Move to review first — unless the user already moved it there by hand.
  local status moved=0
  status=$(_jr_api GET "/issue/$ticket?fields=status" | python3 -c "
import json, sys
print((json.load(sys.stdin).get('fields', {}).get('status') or {}).get('name', ''))
")
  [[ -n "$status" ]] || { echo "jr: ticket not found: $ticket" >&2; return 1; }
  if [[ "${status,,}" == *review* ]]; then
    echo "$ticket already in '$status' — skipping move"
  else
    cmd_move "$ticket" "review" || return 1
    moved=1
  fi

  # Find (and, if needed, wait for) the review template comment, then fill it in.
  # Moving to review triggers the workflow's auto-template, which can lag a few
  # seconds; poll for it.  On a re-resolve (kicked-back ticket) there will be a
  # prior filled comment — in that case post a lightweight follow-up instead of
  # the full template.
  local tries=10 state cid
  while :; do
    state=$(_jr_api GET "/issue/$ticket/comment" | _jr_resolved_state "$me")
    case "$state" in
      TEMPLATE:*)
        cid=${state#TEMPLATE:}
        _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$body" \
          "failed to update Resolved comment $cid on $ticket" || return 1
        echo "$ticket → Resolved comment filled in (replaced template $cid)"
        return 0 ;;
      TEMPLATE_RETRY:*)
        # Re-resolve after kickback: the move re-triggered the template, so edit
        # that comment in place (keep its title, swap the body) instead of
        # posting a new one.
        cid=${state#TEMPLATE_RETRY:}
        local orig retry_body
        orig=$(_jr_api GET "/issue/$ticket/comment/$cid") || return 1
        retry_body=$(_jr_resolve_retry_adf "$orig" "$pr") || return 1
        _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$retry_body" \
          "failed to update Resolved comment $cid on $ticket" || return 1
        echo "$ticket → Resolved comment updated (review feedback addressed, template $cid)"
        return 0 ;;
      FILLED:*)
        cid=${state#FILLED:}
        # If we just moved the ticket, keep polling — the new template may be lagging.
        if [[ $moved -eq 1 && $tries -gt 0 ]]; then
          [[ $tries -eq 10 ]] && echo "jr: waiting for the review template comment to appear…"
          tries=$((tries - 1)); sleep 2; continue
        fi
        if [[ $force -eq 1 ]]; then
          # No fresh template here — post a standalone note (empty orig → it
          # uses the built-in flagged title).
          local retry_body
          retry_body=$(_jr_resolve_retry_adf "{}" "$pr") || return 1
          _jr_comment_write POST "/issue/$ticket/comment" "$retry_body" \
            "failed to post Resolved comment to $ticket" || return 1
          echo "$ticket → Resolved comment added (review feedback addressed, --force)"
          return 0
        fi
        echo "jr: $ticket already has a filled Resolved comment ($cid)." >&2
        echo "    Re-run with --force/-f to add a re-resolve comment." >&2
        return 1 ;;
      *)
        if [[ $tries -gt 0 ]]; then
          [[ $tries -eq 10 ]] && echo "jr: waiting for the review template comment to appear…"
          tries=$((tries - 1)); sleep 2; continue
        fi
        # Automation didn't produce a template (disabled/slow): post a fresh one.
        echo "jr: no template appeared; posting a new Resolved comment instead"
        _jr_comment_write POST "/issue/$ticket/comment" "$body" \
          "failed to post Resolved comment to $ticket" || return 1
        echo "$ticket → Resolved comment added"
        return 0 ;;
    esac
  done
}

# Build the filled "Merge Results" comment ADF (mirrors the workflow's orange
# template). Values come from env: MR_REPO / MR_SRC / MR_TGT. "Was source branch
# removed?" is Yes (we squash/merge with deleteBranchOnMerge); the CI cell stays
# :question: (CI hasn't finished at merge time).
_jr_merge_adf() {
  MR_REPO="$1" MR_SRC="$2" MR_TGT="$3" python3 <<'PYEOF'
import json, os
FLAG = {"type": "emoji", "attrs": {"shortName": ":flag_on:", "id": "atlassian-flag_on", "text": ":flag_on:"}}
Q = {"type": "emoji", "attrs": {"shortName": ":question:", "id": "atlassian-question_mark", "text": ":question:"}}

repo = os.environ.get("MR_REPO", "")
src  = os.environ.get("MR_SRC", "")
tgt  = os.environ.get("MR_TGT", "")

def header(text):
    return {"type": "tableHeader", "content": [{"type": "paragraph", "content": [{"type": "text", "text": text, "marks": [{"type": "strong"}]}]}]}

def cell_text(text):
    if text:
        return {"type": "tableCell", "content": [{"type": "paragraph", "content": [{"type": "text", "text": text}]}]}
    return {"type": "tableCell", "content": [{"type": "paragraph"}]}

def cell_nodes(nodes):
    return {"type": "tableCell", "content": [{"type": "paragraph", "content": nodes}]}

table = {"type": "table", "attrs": {"isNumberColumnEnabled": False, "layout": "default"}, "content": [
    {"type": "tableRow", "content": [
        header("Repository"), header("Source branch"), header("Target branch"),
        header("Was source branch removed?"), header("Target branch CI pipeline passed post merge?")]},
    {"type": "tableRow", "content": [
        cell_text(repo), cell_text(src), cell_text(tgt),
        cell_text("Yes"), cell_nodes([Q])]},
]}

content = [
    {"type": "heading", "attrs": {"level": 2},
     "content": [FLAG, {"type": "text", "text": " Merge Results", "marks": [{"type": "textColor", "attrs": {"color": "#ffa500"}}]}]},
    {"type": "heading", "attrs": {"level": 3}, "content": [{"type": "text", "text": "Details of merge"}]},
    table,
    {"type": "paragraph", "content": [{"type": "text", "text": "Action:", "marks": [{"type": "strong"}]}, {"type": "text", "text": " Ready to Test in Main"}]},
]
print(json.dumps({"body": {"type": "doc", "version": 1, "content": content}}))
PYEOF
}

# Classify the "Merge Results" comments on a ticket. Reads the comment list on
# stdin and my accountId as argv1; prints one of:
#   TEMPLATE:<id>  unfilled template authored by me (data row carries no text yet)
#   FILLED:<id>    a Merge Results comment I already filled in
#   OTHER:<id>     a Merge Results comment authored by someone else (out of scope)
#   NONE:          no Merge Results comment at all
# Mine takes precedence over someone else's; an unfilled template over a filled one.
_jr_merge_state() {
  python3 -c "
import json, sys
me = sys.argv[1]

def find_table(node):
    if isinstance(node, dict):
        if node.get('type') == 'table':
            return node
        for v in node.get('content', []):
            r = find_table(v)
            if r: return r
    return None

def count_text(node):
    n = 0
    if isinstance(node, dict):
        if node.get('type') == 'text': n += 1
        for v in node.get('content', []): n += count_text(v)
    elif isinstance(node, list):
        for v in node: n += count_text(v)
    return n

template = filled = other = None
for c in json.load(sys.stdin).get('comments', []):
    body = c.get('body', {})
    s = json.dumps(body)
    if 'atlassian-flag_on' not in s or 'Merge Results' not in s:
        continue
    if (c.get('author') or {}).get('accountId') != me:
        other = c['id']; continue
    tbl = find_table(body)
    data_text = count_text(tbl['content'][1]) if tbl and len(tbl.get('content', [])) > 1 else 0
    if data_text == 0:
        template = c['id']
    else:
        filled = c['id']

if template: print('TEMPLATE:' + template)
elif filled: print('FILLED:' + filled)
elif other:  print('OTHER:' + other)
else:        print('NONE:')
" "$1"
}

cmd_merge() {
  local force=0 rest=()
  local a
  for a in "$@"; do
    case "$a" in
      --force) force=1 ;;
      *)       rest+=("$a") ;;
    esac
  done
  set -- "${rest[@]}"
  local ticket
  ticket=$(_jr_resolve_ticket "${1:-.}") || return 1

  command -v gh >/dev/null 2>&1 || { echo "jr: gh CLI not found (needed to read/merge the PR)" >&2; return 1; }

  # PR for the current branch, with mergeability + authorship.
  local pr
  if ! pr=$(gh pr view --json number,state,mergeable,author,headRefName,baseRefName,headRepository 2>&1); then
    echo "jr: no PR found for the current branch." >&2
    echo "    Run from the repo with the feature branch checked out." >&2
    echo "    If this repo needs a specific GitHub account, check gh / GH_PROFILE." >&2
    echo "    gh: $pr" >&2
    return 1
  fi

  local state mergeable number author head base repo
  { read -r state; read -r mergeable; read -r number; read -r author; read -r head; read -r base; read -r repo; } < <(echo "$pr" | python3 -c "
import json, sys
p = json.load(sys.stdin)
print(p.get('state') or '')
print(p.get('mergeable') or '')
print(p.get('number') or '')
print((p.get('author') or {}).get('login') or '')
print(p.get('headRefName') or '')
print(p.get('baseRefName') or '')
print((p.get('headRepository') or {}).get('name') or '')
")

  # Merge the PR (skip if already merged). Mergeability is mandatory: conflicts
  # must be resolved and the PR re-approved by hand first — that's out of scope.
  if [[ "$state" == "MERGED" ]]; then
    echo "PR #$number already merged — skipping merge"
  elif [[ "$state" != "OPEN" ]]; then
    echo "jr: PR #$number is $state, not open; refusing to merge." >&2
    return 1
  else
    if [[ "$mergeable" != "MERGEABLE" ]]; then
      echo "jr: PR #$number is not mergeable (mergeable=$mergeable)." >&2
      echo "    Resolve conflicts and get it re-approved, then retry." >&2
      return 1
    fi
    # Method by authorship: mine → squash; someone else's → merge (keep their
    # commits with the original author).
    local me_gh method
    me_gh=$(gh api user -q .login 2>/dev/null)
    if [[ -n "$me_gh" && "$author" == "$me_gh" ]]; then
      method=squash
    else
      method=merge
    fi
    echo "merging PR #$number via --$method (author: ${author:-?})…"
    local out
    if ! out=$(gh pr merge "$number" "--$method" 2>&1); then
      echo "jr: failed to merge PR #$number" >&2
      echo "    gh: $out" >&2
      return 1
    fi
    echo "PR #$number merged (--$method)"
  fi

  # --- Jira side: move Merge → Test in Main, then fill the Merge Results template.
  local me
  me=$(_jr_api GET "/myself" | python3 -c "import json, sys; print(json.load(sys.stdin).get('accountId', ''))")
  [[ -n "$me" ]] || { echo "jr: could not determine the current Jira user" >&2; return 1; }

  local status
  status=$(_jr_api GET "/issue/$ticket?fields=status" | python3 -c "
import json, sys
print((json.load(sys.stdin).get('fields', {}).get('status') or {}).get('name', ''))
")
  [[ -n "$status" ]] || { echo "jr: ticket not found: $ticket" >&2; return 1; }
  if [[ "${status,,}" == *"test in main"* ]]; then
    echo "$ticket already in '$status' — skipping move"
  else
    cmd_move "$ticket" "Test in Main" || return 1
  fi

  # Moving to Test in Main triggers the workflow's "Merge Results" template,
  # authored by us; poll for it and PUT-fill the table. If the only template
  # present was authored by someone else, they already drove this transition —
  # out of jr merge's scope; leave it untouched.
  local mbody
  mbody=$(_jr_merge_adf "$repo" "$head" "$base") || return 1

  local tries=10 mstate cid
  while :; do
    mstate=$(_jr_api GET "/issue/$ticket/comment" | _jr_merge_state "$me")
    case "$mstate" in
      TEMPLATE:*)
        cid=${mstate#TEMPLATE:}
        _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$mbody" \
          "failed to fill Merge Results comment $cid on $ticket" || return 1
        echo "$ticket → Merge Results comment filled in (template $cid)"
        return 0 ;;
      FILLED:*)
        cid=${mstate#FILLED:}
        if [[ $force -eq 1 ]]; then
          _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$mbody" \
            "failed to overwrite Merge Results comment $cid on $ticket" || return 1
          echo "$ticket → Merge Results comment overwritten (--force, comment $cid)"
          return 0
        fi
        echo "jr: $ticket already has a filled Merge Results comment ($cid); not overwriting." >&2
        echo "    Re-run with --force to replace it." >&2
        return 1 ;;
      OTHER:*)
        echo "jr: $ticket has a Merge Results comment authored by someone else — they already moved it on; out of scope, leaving it untouched."
        return 0 ;;
      *)
        if [[ $tries -gt 0 ]]; then
          [[ $tries -eq 10 ]] && echo "jr: waiting for the Merge Results template comment to appear…"
          tries=$((tries - 1)); sleep 2; continue
        fi
        echo "jr: no template appeared; posting a new Merge Results comment instead"
        _jr_comment_write POST "/issue/$ticket/comment" "$mbody" \
          "failed to post Merge Results comment to $ticket" || return 1
        echo "$ticket → Merge Results comment added"
        return 0 ;;
    esac
  done
}

# Build the filled "Code Review Checklist" comment ADF (blue template). If a
# template comment's ADF is passed in REVIEW_TEMPLATE, transform it in place —
# keep the first 3 and the last data row, drop the rest, tick the Done column,
# blank the Comments column, and reduce the Action line to "Ready for test".
# Without a template (REVIEW_TEMPLATE empty) build the checklist from scratch.
# KEEP_SQL/KEEP_JENKINS (default 1) drop the SQL / Jenkins rows when set to 0,
# for tickets with no SQL changes or projects with no Jenkins pipeline.
_jr_approve_adf() {
  REVIEW_TEMPLATE="${REVIEW_TEMPLATE:-}" KEEP_SQL="${KEEP_SQL:-1}" KEEP_JENKINS="${KEEP_JENKINS:-1}" python3 <<'PYEOF'
import json, os

FLAG  = {"type": "emoji", "attrs": {"shortName": ":flag_on:", "id": "atlassian-flag_on", "text": ":flag_on:"}}
CHECK = {"type": "emoji", "attrs": {"shortName": ":check_mark:", "id": "atlassian-check_mark", "text": ":check_mark:"}}

keep_sql     = os.environ.get("KEEP_SQL", "1") != "0"
keep_jenkins = os.environ.get("KEEP_JENKINS", "1") != "0"

def find_table(node):
    if isinstance(node, dict):
        if node.get("type") == "table":
            return node
        for v in node.get("content", []):
            r = find_table(v)
            if r: return r
    elif isinstance(node, list):
        for v in node:
            r = find_table(v)
            if r: return r
    return None

def node_text(n):
    out = ""
    if isinstance(n, dict):
        if n.get("type") == "text":
            out += n.get("text", "")
        for v in n.get("content", []):
            out += node_text(v)
    elif isinstance(n, list):
        for v in n:
            out += node_text(v)
    return out

# A row is dropped if its Area names a section we were told to omit.
def drop_row(row):
    cells = row.get("content", [])
    area = node_text(cells[0]).lower() if cells else ""
    if not keep_sql and "sql" in area:
        return True
    if not keep_jenkins and "jenkins" in area:
        return True
    return False

def done_cell():
    return {"type": "tableCell", "attrs": {}, "content": [{"type": "paragraph", "content": [CHECK]}]}

def empty_cell():
    return {"type": "tableCell", "attrs": {}, "content": [{"type": "paragraph"}]}

def set_action(doc):
    for node in doc.get("content", []):
        if node.get("type") == "paragraph":
            txt = "".join(t.get("text", "") for t in node.get("content", []) if t.get("type") == "text")
            if txt.strip().startswith("Action:"):
                node["content"] = [{"type": "text", "text": "Action:", "marks": [{"type": "strong"}]},
                                   {"type": "text", "text": " Ready for test"}]
                return True
    return False

raw = os.environ.get("REVIEW_TEMPLATE", "").strip()
doc = None
if raw:
    try:
        d = json.loads(raw)
        if isinstance(d, dict) and d.get("type") == "doc":
            doc = d
    except Exception:
        doc = None

tbl = find_table(doc) if doc else None
if doc and tbl:
    rows = tbl.get("content", [])
    header, data = rows[:1], rows[1:]
    n = len(data)
    idxs = [i for i in (0, 1, 2) if i < n]
    if n > 0 and (n - 1) not in idxs:
        idxs.append(n - 1)
    kept = [data[i] for i in idxs if not drop_row(data[i])]
    for row in kept:
        cells = row.get("content", [])
        if len(cells) >= 2: cells[1] = done_cell()
        if len(cells) >= 3: cells[2] = empty_cell()
    tbl["content"] = header + kept
    if not set_action(doc):
        doc.setdefault("content", []).append({"type": "paragraph", "content": [
            {"type": "text", "text": "Action:", "marks": [{"type": "strong"}]},
            {"type": "text", "text": " Ready for test"}]})
    print(json.dumps({"body": doc}))
else:
    def header_cell(text):
        return {"type": "tableHeader", "attrs": {}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": text, "marks": [{"type": "strong"}]}]}]}
    def area_cell(text):
        return {"type": "tableCell", "attrs": {}, "content": [{"type": "paragraph", "content": [{"type": "text", "text": text}]}]}
    AREAS = ["Coding Standards", "Code functional"]
    if keep_sql:
        AREAS.append("SQL Standards - script was already run in DFXDDT and in correct folder")
    if keep_jenkins:
        AREAS.append("Jenkins pipelines (passing if applicable)")
    rows = [{"type": "tableRow", "content": [header_cell("Area"), header_cell("Done"), header_cell("Comments")]}]
    for a in AREAS:
        rows.append({"type": "tableRow", "content": [area_cell(a), done_cell(), empty_cell()]})
    table = {"type": "table", "attrs": {"isNumberColumnEnabled": False, "layout": "default"}, "content": rows}
    content = [
        {"type": "heading", "attrs": {"level": 2},
         "content": [FLAG, {"type": "text", "text": " Code Review Checklist", "marks": [{"type": "textColor", "attrs": {"color": "#00bfff"}}]}]},
        table,
        {"type": "paragraph", "content": [{"type": "text", "text": "Action:", "marks": [{"type": "strong"}]}, {"type": "text", "text": " Ready for test"}]},
    ]
    print(json.dumps({"body": {"type": "doc", "version": 1, "content": content}}))
PYEOF
}

# Classify the "Code Review Checklist" comments on a ticket. Reads the comment
# list on stdin and my accountId as argv1; prints one of:
#   TEMPLATE:<id>  unfilled template authored by me (Done column has no ticks yet)
#   FILLED:<id>    a checklist I already ticked
#   OTHER:<id>     a checklist authored by someone else (out of scope)
#   NONE:          no Code Review Checklist comment at all
# Mine takes precedence over someone else's; an unfilled template over a filled one.
_jr_approve_state() {
  python3 -c "
import json, sys
me = sys.argv[1]
template = filled = other = None
for c in json.load(sys.stdin).get('comments', []):
    s = json.dumps(c.get('body', {}))
    if 'atlassian-flag_on' not in s or 'Code Review Checklist' not in s:
        continue
    if (c.get('author') or {}).get('accountId') != me:
        other = c['id']; continue
    if 'atlassian-check_mark' in s:
        filled = c['id']
    else:
        template = c['id']
if template: print('TEMPLATE:' + template)
elif filled: print('FILLED:' + filled)
elif other:  print('OTHER:' + other)
else:        print('NONE:')
" "$1"
}

cmd_approve() {
  local force=0 keep_sql=1 keep_jenkins=1 rest=()
  local a opt c i
  for a in "$@"; do
    case "$a" in
      --force)      force=1 ;;
      --no-sql)     keep_sql=0 ;;
      --no-jenkins) keep_jenkins=0 ;;
      # Bundled short flags: -s skip SQL, -j skip Jenkins, -f force (e.g. -sj, -sjf).
      -[sjf]*)
        opt=${a#-}
        for (( i=0; i<${#opt}; i++ )); do
          c=${opt:i:1}
          case "$c" in
            s) keep_sql=0 ;;
            j) keep_jenkins=0 ;;
            f) force=1 ;;
            *) echo "jr: unknown option -$c (in '$a')" >&2; return 1 ;;
          esac
        done ;;
      *)            rest+=("$a") ;;
    esac
  done
  set -- "${rest[@]}"
  export KEEP_SQL="$keep_sql" KEEP_JENKINS="$keep_jenkins"
  local ticket
  ticket=$(_jr_resolve_ticket "${1:-.}") || return 1

  local me
  me=$(_jr_api GET "/myself" | python3 -c "import json, sys; print(json.load(sys.stdin).get('accountId', ''))")
  [[ -n "$me" ]] || { echo "jr: could not determine the current Jira user" >&2; return 1; }

  # Move Review → Test in Branch first — unless it's already there.
  local status
  status=$(_jr_api GET "/issue/$ticket?fields=status" | python3 -c "
import json, sys
print((json.load(sys.stdin).get('fields', {}).get('status') or {}).get('name', ''))
")
  [[ -n "$status" ]] || { echo "jr: ticket not found: $ticket" >&2; return 1; }
  if [[ "${status,,}" == *"test in branch"* ]]; then
    echo "$ticket already in '$status' — skipping move"
  else
    cmd_move "$ticket" "Test in Branch" || return 1
  fi

  # Moving to Test in Branch triggers the workflow's "Code Review Checklist"
  # template, authored by us; poll for it and transform-fill it. If the only
  # checklist present was authored by someone else, they already drove this
  # transition — out of scope; leave it untouched.
  local tries=10 state cid tbody body
  while :; do
    state=$(_jr_api GET "/issue/$ticket/comment" | _jr_approve_state "$me")
    case "$state" in
      TEMPLATE:*)
        cid=${state#TEMPLATE:}
        tbody=$(_jr_api GET "/issue/$ticket/comment/$cid" | python3 -c "import json, sys; print(json.dumps(json.load(sys.stdin).get('body', {})))")
        body=$(REVIEW_TEMPLATE="$tbody" _jr_approve_adf) || return 1
        _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$body" \
          "failed to fill Code Review Checklist comment $cid on $ticket" || return 1
        echo "$ticket → Code Review Checklist filled in (template $cid)"
        return 0 ;;
      FILLED:*)
        cid=${state#FILLED:}
        if [[ $force -eq 1 ]]; then
          tbody=$(_jr_api GET "/issue/$ticket/comment/$cid" | python3 -c "import json, sys; print(json.dumps(json.load(sys.stdin).get('body', {})))")
          body=$(REVIEW_TEMPLATE="$tbody" _jr_approve_adf) || return 1
          _jr_comment_write PUT "/issue/$ticket/comment/$cid" "$body" \
            "failed to overwrite Code Review Checklist comment $cid on $ticket" || return 1
          echo "$ticket → Code Review Checklist overwritten (--force, comment $cid)"
          return 0
        fi
        echo "jr: $ticket already has a filled Code Review Checklist ($cid); not overwriting." >&2
        echo "    Re-run with --force to replace it." >&2
        return 1 ;;
      OTHER:*)
        echo "jr: $ticket has a Code Review Checklist authored by someone else — out of scope, leaving it untouched."
        return 0 ;;
      *)
        if [[ $tries -gt 0 ]]; then
          [[ $tries -eq 10 ]] && echo "jr: waiting for the Code Review Checklist template comment to appear…"
          tries=$((tries - 1)); sleep 2; continue
        fi
        echo "jr: no template appeared; posting a new Code Review Checklist instead"
        body=$(_jr_approve_adf) || return 1
        _jr_comment_write POST "/issue/$ticket/comment" "$body" \
          "failed to post Code Review Checklist to $ticket" || return 1
        echo "$ticket → Code Review Checklist added"
        return 0 ;;
    esac
  done
}

cmd_set_field() {
  # jr set-field <TICKET> <FIELD> <VALUE>        — set a field (select: {"value":"V"}, raw JSON: pass {…})
  # jr set-field <TICKET> <FIELD> --list-options — list allowed option values for a select field
  [[ $# -lt 2 ]] && {
    echo "Usage: jr set-field <TICKET> <FIELD> <VALUE|--list-options>" >&2
    echo "  FIELD: customfield_XXXXX or a case-insensitive name (e.g. CapEx)" >&2
    return 1
  }
  local ticket field_input value_input
  ticket=$(_jr_resolve_ticket "$1") || return 1
  field_input=$2; value_input=${3:-}

  # Resolve field name → ID
  local field_id field_name
  if [[ "$field_input" =~ ^customfield_[0-9]+$ ]]; then
    field_id=$field_input; field_name=$field_input
  else
    local fields_json resolved
    fields_json=$(_jr_api GET "/field") || { echo "jr: failed to fetch field list" >&2; return 1; }
    resolved=$(echo "$fields_json" | python3 -c "
import json, sys
target = sys.argv[1].lower()
fs = json.load(sys.stdin)
for f in fs:
    if f.get('name','').lower() == target:
        print(f['id'] + '|' + f.get('name','')); sys.exit(0)
matches = [f for f in fs if target in f.get('name','').lower()]
if len(matches) == 1:
    print(matches[0]['id'] + '|' + matches[0].get('name','')); sys.exit(0)
if len(matches) > 1:
    print('AMBIGUOUS:' + '||'.join(f['id']+':'+f['name'] for f in matches[:10]))
else:
    print('NONE:')
" "$field_input")
    case "$resolved" in
      AMBIGUOUS:*) echo "jr: '$field_input' matches multiple fields — be more specific:" >&2
                   echo "${resolved#AMBIGUOUS:}" | tr '|' '\n' | grep ':' | sed 's/^/  /' >&2
                   return 1 ;;
      NONE:)       echo "jr: no field matching '$field_input'" >&2; return 1 ;;
      *'|'*)       field_id=${resolved%%|*}; field_name=${resolved#*|} ;;
      *)           echo "jr: unexpected field resolution: $resolved" >&2; return 1 ;;
    esac
  fi

  # --list-options: show allowed values via issue editmeta (no admin needed)
  if [[ "$value_input" == "--list-options" ]]; then
    _jr_api GET "/issue/$ticket/editmeta" | python3 -c "
import json, sys
fid = sys.argv[1]
f = json.load(sys.stdin).get('fields', {}).get(fid, {})
name = f.get('name', fid)
allowed = f.get('allowedValues', [])
if not allowed:
    print(f'jr: no options found for {name} ({fid}) — may not be a select field', file=sys.stderr)
    sys.exit(1)
print(f'Options for {name} ({fid}):')
for opt in allowed:
    val = opt.get('value') or opt.get('name', '')
    print('  id=%-8s  %s' % (opt.get('id',''), val))
" "$field_id"
    return $?
  fi

  [[ -z "$value_input" ]] && {
    echo "Usage: jr set-field <TICKET> <FIELD> <VALUE|--list-options>" >&2; return 1
  }

  # Build PATCH value: raw JSON passthrough, numbers as-is, else wrap in {"value":"..."}
  local field_value
  if [[ "$value_input" == \{* || "$value_input" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    field_value=$value_input
  else
    field_value="{\"value\":\"$value_input\"}"
  fi

  local resp code body
  resp=$(_jr_api_status PATCH "/issue/$ticket" "{\"fields\":{\"$field_id\":$field_value}}")
  code=${resp##*$'\n'}; body=${resp%$'\n'*}

  if [[ ! "$code" =~ ^2 ]]; then
    echo "jr: failed to set ${field_name:-$field_id} on $ticket (HTTP $code)" >&2
    echo "$body" | python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    for m in d.get('errorMessages', []): print('   ', m)
    for k, v in d.get('errors', {}).items(): print(f'    {k}: {v}')
except Exception:
    pass
" >&2
    echo "    Hint: jr set-field $ticket $field_id --list-options" >&2
    return 1
  fi
  echo "$ticket  ${field_name:-$field_id} = $value_input"
}

