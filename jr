cmd_open() {
  local print_only=0
  local rest=()
  local a
  for a in "$@"; do
    case "$a" in
      --print|-p) print_only=1 ;;
      *)          rest+=("$a") ;;
    esac
  done
  set -- "${rest[@]}"
  local ticket
  ticket=$(_jr_resolve_ticket "${1:-.}") || return 1
  local url="${JIRA_BASE%/}/browse/$ticket"
  if [[ $print_only -eq 1 ]]; then
    echo "$url"
  else
    python3 -c "import sys, webbrowser; webbrowser.open(sys.argv[1])" "$url"
    echo "$ticket  $url"
  fi
}

